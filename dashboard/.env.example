# Public app URL (used in auth callback links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase client keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server key (not required for normal dashboard runtime)
SUPABASE_SERVICE_ROLE_KEY=

# Modal Phase 3 select-agent webhook
MODAL_WEBHOOK_SELECT_AGENT=
# Modal Phase 4 land-freight market-rates webhook (fetch_market_rates)
MODAL_WEBHOOK_MARKET_RATES=

# Optional Modal webhook hardening
MODAL_WEBHOOK_SECRET=
MODAL_WEBHOOK_TIMEOUT_MS=15000

# Feature flags (gate freight-mode UI; set to "true" to enable)
NEXT_PUBLIC_FEATURE_AIR_FREIGHT=false
NEXT_PUBLIC_FEATURE_LAND_FREIGHT=false
# Phase 4 — external land-freight API rate intelligence (Market Rates tab)
NEXT_PUBLIC_FEATURE_LAND_API_RATES=false

# Workspace mailbox OAuth (Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to <site-url>/api/workspaces/current/mailbox/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Gmail watch topic for immediate watch setup after OAuth connect
GOOGLE_PUBSUB_TOPIC=

# Shared token encryption key (32-byte key in base64url/base64/hex/raw)
MAILBOX_TOKEN_ENCRYPTION_KEY=
# Optional dedicated state-signing secret (falls back to MAILBOX_TOKEN_ENCRYPTION_KEY)
MAILBOX_OAUTH_STATE_SECRET=
