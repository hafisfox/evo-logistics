# ==============================================================================
# ENVIRONMENT VARIABLES FOR MODAL AUTOMATIONS
# Copy this file to '.env' and fill in production values, then sync to:
#   modal secret create evo-logistics-env --from-dotenv automations/.env --force
# ==============================================================================

# OpenAI keys
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
MODAL_LLM_API_KEY="modalresearch_..."

# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Gmail + Pub/Sub
GOOGLE_PUBSUB_TOPIC="projects/your-project-id/topics/gmail-push-notifications"
GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-oauth-client-secret"
MAILBOX_TOKEN_ENCRYPTION_KEY="32-byte-key-as-base64url-base64-hex-or-raw"

# Workspace routing controls
BOOTSTRAP_WORKSPACE_ID="00000000-0000-0000-0000-000000000001"
ALLOW_BOOTSTRAP_WORKSPACE_FALLBACK="false"
