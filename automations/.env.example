# ==============================================================================
# LOCAL ENVIRONMENT VARIABLES FOR MODAL execution
# Copy this file to '.env' and fill in your actual credentials.
# Modal will automatically inject these variables into the cloud when you run:
# modal run <script>.py
# ==============================================================================

# Your OpenAI API key starting with 'sk-...'
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# Your Google Cloud Service Account JSON Key
# Copy the ENTIRE JSON string (collapsed to one line) provided by Google Cloud.
# Example: {"type": "service_account", "project_id": "pricing-auto-123", ... }
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type": "service_account", "project_id": "xxxx"}'

# Google Cloud Pub/Sub topic for Gmail push notifications
# Format: projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME
GOOGLE_PUBSUB_TOPIC="projects/your-project-id/topics/gmail-push-notifications"
